{
    "compilerOptions": {
      "target": "ES2020",
      "module": "commonjs",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "outDir": "./dist",
      "baseUrl": "./src",
      "paths": {
        "*": ["node_modules/*"]
      },
      "typeRoots": ["./node_modules/@types", "./src/shared/types"]
    },
    "include": ["src/**/*", "src/shared/types/express.d.ts"],
    "exclude": ["node_modules", "dist"]
  }
  